# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Variáveis de ambiente do backend ERP
# Copie este arquivo para .env e ajuste os valores.
# O arquivo .env real NUNCA deve ser commitado no Git (.gitignore já o exclui).
# ─────────────────────────────────────────────────────────────────────────────

# ── BANCO DE DADOS ───────────────────────────────────────────────────────────

# OPÇÃO 1 — Desenvolvimento local simples (SQLite, sem instalação):
# DATABASE_URL=sqlite:///./backend/erp_antigravity.db

# OPÇÃO 2 — Desenvolvimento local com PostgreSQL via Neon.tech (recomendado):
# Crie conta grátis em neon.tech, copie a connection string do projeto "erp-dev"
DATABASE_URL=postgresql://usuario:senha@ep-xxx.neon.tech/neondb?sslmode=require

# OPÇÃO 3 — Produção Render.com (PostgreSQL — injetado automaticamente pelo Render):
# DATABASE_URL=postgresql://erp_user:senha@oregon-postgres.render.com/erp_production

# OPÇÃO 4 — VPS HostGator com PostgreSQL instalado:
# DATABASE_URL=postgresql://erp_user:senha@localhost:5432/erp_db

# ── CORS (origens permitidas) ─────────────────────────────────────────────────
# Em produção, liste a URL do seu frontend separada por vírgulas.
# ALLOWED_ORIGINS=https://erp-frontend.onrender.com,https://erp-frontend.onrender.com
